#!/usr/bin/env bash
# =============================================================================
# CR380 - Docker Swarm Lab — Configuration centrale / Central configuration
# =============================================================================
#
# FR: Modifier ce fichier pour mettre à jour les versions d'images, les noms
#     de services et les délais d'attente avant chaque session de cours.
# EN: Edit this file to update image versions, service names, and timeouts
#     before each class session.
#
# =============================================================================

# -----------------------------------------------------------------------------
# Délais d'attente / Timeouts (seconds)
# -----------------------------------------------------------------------------
TIMEOUT_DEFAULT=30
TIMEOUT_PULL=180
TIMEOUT_STACK_CONVERGE=120
TIMEOUT_CONTAINER_READY=60

# -----------------------------------------------------------------------------
# Prérequis / Prerequisites
# -----------------------------------------------------------------------------
MIN_DISK_GB=10

# -----------------------------------------------------------------------------
# GitBook
# -----------------------------------------------------------------------------
GITBOOK_BASE_URL="https://polytechnique-montreal.gitbook.io/cr380/uypezSjfF3TINgWe4QZx"

# =============================================================================
# Lab-specific config / Configuration par lab
# =============================================================================

# -----------------------------------------------------------------------------
# Directories / Répertoires
# -----------------------------------------------------------------------------
STACK_DIR="${PROJECT_DIR}/stack-files"

# -----------------------------------------------------------------------------
# Lab 01 — Swarm Init
# -----------------------------------------------------------------------------
# (no extra config needed — uses docker swarm init)

# -----------------------------------------------------------------------------
# Lab 02 — Overlay Network
# -----------------------------------------------------------------------------
SWARM_NETWORK_NAME="scalenet"
SWARM_NETWORK_DRIVER="overlay"

# -----------------------------------------------------------------------------
# Lab 03 — Database Stack
# -----------------------------------------------------------------------------
STACK_DATABASE_FILE="${STACK_DIR}/stack.database.yaml"
STACK_DATABASE_NAME="database"
SVC_MARIADB="mariadb"
SVC_ADMINER="adminer"
PORT_MARIADB=3306
PORT_ADMINER=8081

# -----------------------------------------------------------------------------
# Lab 04 — Web App Stack (Drupal)
# -----------------------------------------------------------------------------
STACK_DRUPAL_FILE="${STACK_DIR}/stack.drupal.yaml"
STACK_DRUPAL_NAME="drupalsite"
SVC_DRUPAL="drupal"
PORT_DRUPAL=80

# -----------------------------------------------------------------------------
# Lab 06 — Horizontal Scaling
# -----------------------------------------------------------------------------
SCALE_OUT_REPLICAS=5
SCALE_IN_REPLICAS=2
SCALE_DEFAULT_REPLICAS=1
